{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || (root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'))",
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "!newData.exists() || newData.hasChildren(['name', 'email', 'role', 'active'])",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "email": { ".validate": "newData.isString() && newData.val().length > 3 && newData.val().length <= 160" },
        "role": { ".validate": "newData.val() === 'admin' || newData.val() === 'seller' || newData.val() === 'door'" },
        "active": { ".validate": "newData.isBoolean()" },
        "eventIds": {
          "$eventId": { ".validate": "newData.val() === true && root.child('events').child($eventId).exists()" }
        }
      }
    },
    "events": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["date"],
      "$eventId": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('eventIds').child($eventId).val() === true)",
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "sales": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || ((root.child('users').child(auth.uid).child('role').val() === 'seller' || root.child('users').child(auth.uid).child('role').val() === 'door') && query.orderByChild === 'eventId' && query.equalTo != null && root.child('users').child(auth.uid).child('eventIds').child(query.equalTo).val() === true))",
      ".indexOn": ["eventId", "ticketTypeId", "paid", "checkedIn"],
      "$saleId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'seller' && (!data.exists() || root.child('users').child(auth.uid).child('eventIds').child(data.child('eventId').val()).val() === true) && (!newData.exists() || root.child('users').child(auth.uid).child('eventIds').child(newData.child('eventId').val()).val() === true)))",
        "checkedIn": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'door' && root.child('users').child(auth.uid).child('eventIds').child(root.child('sales').child($saleId).child('eventId').val()).val() === true",
          ".validate": "newData.isBoolean()"
        }
      }
    },
    "auditLogs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["eventId", "timestamp"],
      "$logId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && ((!data.exists() && newData.exists() && newData.child('actorUid').val() === auth.uid && newData.child('actorRole').val() === root.child('users').child(auth.uid).child('role').val() && root.child('events').child(newData.child('eventId').val()).exists() && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'seller' && root.child('users').child(auth.uid).child('eventIds').child(newData.child('eventId').val()).val() === true) || (root.child('users').child(auth.uid).child('role').val() === 'door' && newData.child('action').val() === 'checkin' && root.child('users').child(auth.uid).child('eventIds').child(newData.child('eventId').val()).val() === true))) || (data.exists() && !newData.exists() && root.child('users').child(auth.uid).child('role').val() === 'admin'))",
        ".validate": "newData.hasChildren(['eventId', 'eventName', 'saleId', 'participantName', 'ticketTypeName', 'quantity', 'action', 'details', 'timestamp', 'actorUid', 'actorName', 'actorEmail', 'actorRole'])",
        "eventId": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120" },
        "eventName": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 160" },
        "saleId": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120" },
        "participantName": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 160" },
        "ticketTypeName": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 160" },
        "quantity": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "action": { ".validate": "newData.val() === 'created' || newData.val() === 'edited' || newData.val() === 'deleted' || newData.val() === 'payment' || newData.val() === 'checkin'" },
        "details": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500" },
        "timestamp": { ".validate": "newData.isNumber()" },
        "actorUid": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "actorName": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 160" },
        "actorEmail": { ".validate": "newData.isString() && newData.val().length <= 160" },
        "actorRole": { ".validate": "newData.val() === 'admin' || newData.val() === 'seller' || newData.val() === 'door'" }
      }
    }
  }
}
