{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || (root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'))",
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "!newData.exists() || newData.hasChildren(['name', 'email', 'role', 'active'])",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "email": { ".validate": "newData.isString() && newData.val().length > 3 && newData.val().length <= 160" },
        "role": { ".validate": "newData.val() === 'admin' || newData.val() === 'seller' || newData.val() === 'door'" },
        "active": { ".validate": "newData.isBoolean()" }
      }
    },
    "events": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true",
      ".indexOn": ["date"],
      "$eventId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "sales": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true",
      ".indexOn": ["eventId", "ticketTypeId", "paid", "checkedIn"],
      "$saleId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'seller')",
        "checkedIn": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && root.child('users').child(auth.uid).child('role').val() === 'door'",
          ".validate": "newData.isBoolean()"
        }
      }
    }
  }
}
